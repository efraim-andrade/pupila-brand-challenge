#!/bin/sh

echo "Running tests with coverage..."

OUTPUT=$(npm run test:coverage 2>&1)
STATUS=$?

echo "$OUTPUT"

if [ $STATUS -ne 0 ]; then
  echo "Tests failed! Push aborted."
  exit 1
fi

COVERAGE=$(echo "$OUTPUT" | grep -E "^All files" | sed 's/|/ /g' | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, ""); print $3}')

if [ -z "$COVERAGE" ] || ! echo "$COVERAGE" | grep -qE '^[0-9]+\.?[0-9]*$'; then
  echo "Could not determine coverage! Push aborted."
  exit 1
fi

if [ "$(echo "$COVERAGE 85" | awk '{print ($1 < $2) ? 1 : 0}')" -eq 1 ]; then
  echo "Coverage is ${COVERAGE}%, which is below 85%! Push aborted."
  exit 1
fi

echo "All tests passed and coverage is ${COVERAGE}%! Proceeding with push."