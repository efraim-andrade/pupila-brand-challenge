#!/bin/sh

echo "Running typecheck..."

npm run typecheck

if [ $? -ne 0 ]; then
  echo "Typecheck failed! Commit aborted."
  exit 1
fi

echo "Running tests..."

npm test -- --passWithNoTests

if [ $? -ne 0 ]; then
  echo "Tests failed! Commit aborted."
  exit 1
fi

echo "Pre-commit checks passed! Proceeding with commit."